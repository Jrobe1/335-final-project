<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <link rel="stylesheet" href="style.css" title="projectCSS">
    <title>Vote for the Best Option</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&display=swap');
    </style>
</head>
<body>
    <div id="mainContainer">
        <div class="header">
            <br>
            <a href="/"><Button>Home</Button></a>
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
            <a href="/leaderboard"><Button>Top Winners</Button></a>
        </div>
        <h1>Which is the Best?</h1>
        <div id="optionsWindow">
            <div class="optionContainer">
                <div class="imageContainer">
                    <img src="<%- img1url %>"
                        id="img1"
                        class="voteOption">
                </div>
                <h2><%- label1 %></h2>
            </div>
            <div class="optionContainer">
                <div class="imageContainer">
                    <img src="<%- img2url %>"
                        id="img2"
                        class="voteOption">
                </div>
                <h2><%- label2 %></h2>
            </div>
            <div class="optionContainer">
                <div class="imageContainer">
                    <img src="<%- img3url %>"
                        id="img3"
                        class="voteOption">
                </div>
                <h2><%- label3 %></h2>
            </div>
        </div>
        <form id="votingForm">
            <div id="radioContainer">
                <input type="radio" name="voteChoice" value="choice1" required>
                <input type="radio" name="voteChoice" value="choice2">
                <input type="radio" name="voteChoice" value="choice3">
            </div>
            <br><br>
            <input type="submit" value="Vote!">
            <br>
        </form>
        <script>
        </script>
    </div>
</body>
</html>